# secrets.env.example
#
# Copy this file to secrets.env and fill in real values before deploying.
# secrets.env is listed in .gitignore and must NEVER be committed to git.
#
# On the Claude Code server, create secrets.env by running:
#   echo "AUTOVPN_PSK=your-strong-psk-here" > secrets.env
#
# The PSK must:
#   - Be at least 20 characters
#   - Contain mixed case, numbers, and special characters
#   - Be identical on ALL devices (hub and all spokes)

AUTOVPN_PSK=replace-with-your-strong-psk
